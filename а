  let currentPhotoIndex = 0;

  function renderThumbs(){
    const thumbs = document.getElementById('lightboxThumbs');
    thumbs.innerHTML = '';

    photoGallery.forEach(function(src, index){
      const item = document.createElement('div');
      item.className = 'lightbox-thumb' + (index === currentPhotoIndex ? ' active' : '');
      item.innerHTML = `<img src="${src}" alt="Превью ${index + 1}">`;
      item.onclick = function(){
