<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Evgeniy AI Studio — Нейрообработка фото, реставрация и видеопрощание</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;700&family=Montserrat:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#0a0a0f;
      --bg-2:#12121a;
      --gold:#d4af37;
      --gold-light:#f4d77a;
      --neon:#00e5ff;
      --text:#e8e8ec;
      --muted:#9a9aa8;
      --card:#15151f;
      --border:rgba(212,175,55,0.25);
    }

    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}

    body{
      font-family:'Montserrat',sans-serif;
      background:var(--bg);
      color:var(--text);
      overflow-x:hidden;
      line-height:1.6;
    }

    body::before{
      content:'';
      position:fixed;
      inset:0;
      background:
        radial-gradient(circle at 20% 10%, rgba(212,175,55,0.08), transparent 40%),
        radial-gradient(circle at 80% 80%, rgba(0,229,255,0.06), transparent 40%);
      pointer-events:none;
      z-index:0;
    }

    .container{
      max-width:1200px;
      margin:0 auto;
      padding:0 24px;
      position:relative;
      z-index:1;
    }

    header{
      position:fixed;
      top:0;
      left:0;
      right:0;
      z-index:100;
      background:rgba(10,10,15,0.88);
      backdrop-filter:blur(12px);
      border-bottom:1px solid var(--border);
    }

    .nav{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:18px 0;
    }

    .logo{
      font-family:'Cormorant Garamond',serif;
      font-size:26px;
      font-weight:700;
      background:linear-gradient(135deg,var(--gold),var(--gold-light));
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
      letter-spacing:2px;
    }

    .logo span{
      color:var(--neon);
      -webkit-text-fill-color:var(--neon);
    }

    .nav-links{
      display:flex;
      gap:22px;
      list-style:none;
      align-items:center;
      flex-wrap:wrap;
    }

    .nav-links a{
      color:var(--text);
      text-decoration:none;
      font-size:12px;
      letter-spacing:1px;
      text-transform:uppercase;
      transition:color .3s;
      cursor:pointer;
    }

    .nav-links a:hover{
      color:var(--gold);
    }

    .burger{
      display:none;
      background:none;
      border:none;
      color:var(--gold);
      font-size:26px;
      cursor:pointer;
    }

    .btn{
      display:inline-block;
      padding:14px 34px;
      background:linear-gradient(135deg,var(--gold) 0%,var(--gold-light) 100%);
      color:#0a0a0f;
      font-weight:700;
      text-decoration:none;
      border:none;
      cursor:pointer;
      font-size:14px;
      letter-spacing:2px;
      text-transform:uppercase;
      border-radius:2px;
      transition:all .4s;
      font-family:inherit;
      box-shadow:0 0 20px rgba(212,175,55,0.3);
    }

    .btn:hover{
      box-shadow:0 0 35px rgba(212,175,55,0.7),0 0 60px rgba(0,229,255,0.18);
      transform:translateY(-2px);
    }

    .btn-outline{
      background:transparent;
      color:var(--gold);
      border:1px solid var(--gold);
      box-shadow:none;
    }

    .btn-outline:hover{
      background:var(--gold);
      color:#0a0a0f;
    }

    .hero{
      min-height:100vh;
      display:flex;
      align-items:center;
      padding:120px 0 60px;
    }

    .hero-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:60px;
      align-items:center;
    }

    .hero-tag{
      display:inline-block;
      padding:6px 16px;
      border:1px solid var(--gold);
      color:var(--gold);
      font-size:12px;
      letter-spacing:3px;
      text-transform:uppercase;
      margin-bottom:24px;
      border-radius:30px;
    }

    .hero h1{
      font-family:'Cormorant Garamond',serif;
      font-size:62px;
      line-height:1.1;
      font-weight:700;
      margin-bottom:24px;
    }

    .hero h1 .accent{
      background:linear-gradient(135deg,var(--gold),var(--gold-light));
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
    }

    .hero p{
      color:var(--muted);
      font-size:17px;
      margin-bottom:36px;
      max-width:560px;
    }

    .hero-buttons{
      display:flex;
      gap:16px;
      flex-wrap:wrap;
    }

    .hero-image{
      position:relative;
      width:100%;
      max-width:420px;
      margin:0 auto;
      aspect-ratio:9/16;
      border-radius:8px;
      overflow:hidden;
      border:1px solid var(--border);
      box-shadow:0 0 80px rgba(212,175,55,0.15);
    }

    .hero-image img{
      width:100%;
      height:100%;
      object-fit:cover;
      object-position:center top;
    }

    .hero-image::after{
      content:'';
      position:absolute;
      inset:0;
      background:linear-gradient(45deg,transparent 60%,rgba(212,175,55,0.15));
      pointer-events:none;
    }

    section{
      padding:100px 0;
      position:relative;
    }

    .section-tag{
      text-align:center;
      color:var(--neon);
      font-size:12px;
      letter-spacing:4px;
      text-transform:uppercase;
      margin-bottom:12px;
    }

    .section-title{
      font-family:'Cormorant Garamond',serif;
      font-size:48px;
      text-align:center;
      margin-bottom:16px;
      font-weight:700;
    }

    .section-title .accent{
      background:linear-gradient(135deg,var(--gold),var(--gold-light));
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
    }

    .section-sub{
      text-align:center;
      color:var(--muted);
      margin-bottom:60px;
      max-width:820px;
      margin-left:auto;
      margin-right:auto;
    }

    .compare-wrap{
      max-width:736px;
      margin:0 auto;
      border-radius:8px;
      overflow:hidden;
      border:1px solid var(--border);
      box-shadow:0 0 60px rgba(212,175,55,0.2);
      background:#000;
    }

    .compare{
      position:relative;
      width:100%;
      aspect-ratio:736 / 1104;
      user-select:none;
      overflow:hidden;
      cursor:ew-resize;
      background:#000;
    }

    .compare img{
      position:absolute;
      inset:0;
      width:100%;
      height:100%;
      object-fit:contain;
      object-position:center center;
      display:block;
      pointer-events:none;
      background:#000;
    }

    .compare .img-after{
      clip-path:inset(0 0 0 50%);
    }

    .compare .label{
      position:absolute;
      top:20px;
      background:rgba(10,10,15,0.8);
      backdrop-filter:blur(8px);
      color:var(--gold);
      padding:6px 16px;
      font-size:12px;
      letter-spacing:2px;
      text-transform:uppercase;
      border:1px solid var(--gold);
      border-radius:2px;
      pointer-events:none;
      z-index:3;
    }

    .compare .label-before{left:20px}
    .compare .label-after{
      right:20px;
      color:var(--neon);
      border-color:var(--neon);
    }

    .slider-line{
      position:absolute;
      top:0;
      bottom:0;
      width:3px;
      background:linear-gradient(var(--gold),var(--neon));
      left:50%;
      transform:translateX(-50%);
      pointer-events:none;
      box-shadow:0 0 20px var(--gold);
      z-index:3;
    }

    .slider-handle{
      position:absolute;
      top:50%;
      left:50%;
      transform:translate(-50%,-50%);
      width:48px;
      height:48px;
      border-radius:50%;
      background:linear-gradient(135deg,var(--gold),var(--gold-light));
      display:flex;
      align-items:center;
      justify-content:center;
      pointer-events:none;
      box-shadow:0 0 30px rgba(212,175,55,0.7);
      font-size:18px;
      color:#0a0a0f;
      font-weight:bold;
      z-index:3;
    }

    .compare-buttons{
      display:flex;
      gap:10px;
      justify-content:center;
      margin-top:30px;
      flex-wrap:wrap;
    }

    .compare-btn{
      padding:10px 22px;
      background:transparent;
      border:1px solid var(--border);
      color:var(--text);
      cursor:pointer;
      font-size:13px;
      letter-spacing:1px;
      border-radius:2px;
      transition:all .3s;
      font-family:inherit;
    }

    .compare-btn:hover,
    .compare-btn.active{
      border-color:var(--gold);
      color:var(--gold);
      background:rgba(212,175,55,0.05);
    }

    .services{
      background:var(--bg-2);
    }

    .services-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
      gap:24px;
      align-items:start;
    }

    .service-card{
      background:var(--card);
      border:1px solid var(--border);
      padding:36px 28px;
      border-radius:6px;
      transition:all .4s;
      position:relative;
      overflow:hidden;
      height:100%;
    }

    .service-card::before{
      content:'';
      position:absolute;
      top:0;
      left:0;
      right:0;
      height:2px;
      background:linear-gradient(90deg,var(--gold),var(--neon));
      transform:scaleX(0);
      transform-origin:left;
      transition:.4s;
    }

    .service-card:hover{
      transform:translateY(-6px);
      border-color:var(--gold);
      box-shadow:0 20px 50px rgba(212,175,55,0.15);
    }

    .service-card:hover::before{
      transform:scaleX(1);
    }

    .service-icon{
      width:60px;
      height:60px;
      border-radius:50%;
      background:linear-gradient(135deg,rgba(212,175,55,0.15),rgba(0,229,255,0.1));
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:28px;
      margin-bottom:20px;
      border:1px solid var(--border);
    }

    .service-card h3{
      font-family:'Cormorant Garamond',serif;
      font-size:24px;
      margin-bottom:12px;
      color:var(--gold);
    }

    .service-card p{
      color:var(--muted);
      font-size:14px;
      margin-bottom:20px;
    }

    .service-price{
      color:var(--neon);
      font-size:18px;
      font-weight:500;
      margin-bottom:20px;
      display:block;
    }

    .video-feature{
      background:
        linear-gradient(135deg, rgba(212,175,55,0.08), rgba(0,229,255,0.05)),
        #0f0f16;
      border-top:1px solid var(--border);
      border-bottom:1px solid var(--border);
    }

    .video-feature-box{
      border:1px solid rgba(212,175,55,0.22);
      border-radius:16px;
      overflow:hidden;
      background:linear-gradient(180deg, rgba(21,21,31,0.95), rgba(10,10,15,0.98));
      box-shadow:0 0 60px rgba(212,175,55,0.12), 0 0 100px rgba(0,229,255,0.04);
      position:relative;
    }

    .video-feature-inner{
      position:relative;
      z-index:1;
      display:grid;
      grid-template-columns:1fr 1.15fr;
      gap:40px;
      align-items:center;
      padding:50px;
    }

    .video-badge{
      display:inline-block;
      padding:7px 16px;
      border:1px solid var(--gold);
      color:var(--gold);
      font-size:12px;
      letter-spacing:3px;
      text-transform:uppercase;
      border-radius:30px;
      margin-bottom:20px;
    }

    .video-title{
      font-family:'Cormorant Garamond',serif;
      font-size:52px;
      line-height:1.05;
      margin-bottom:20px;
      font-weight:700;
    }

    .video-title .accent{
      background:linear-gradient(135deg,var(--gold),var(--gold-light));
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
    }

    .video-text{
      color:var(--muted);
      font-size:16px;
      margin-bottom:28px;
      max-width:540px;
    }

    .video-points{
      display:grid;
      gap:12px;
      margin-bottom:32px;
    }

    .video-point{
      display:flex;
      gap:12px;
      align-items:flex-start;
      color:var(--text);
      font-size:14px;
    }

    .video-point span{
      color:var(--neon);
      font-weight:700;
      min-width:20px;
    }

    .video-actions{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
    }

    .video-widget-wrap{
      background:#0b0b12;
      border:1px solid rgba(212,175,55,0.18);
      border-radius:14px;
      padding:16px;
      box-shadow:inset 0 0 30px rgba(255,255,255,0.02);
      min-height:420px;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .video-widget-wrap > div{
      width:100%;
      display:flex;
      justify-content:center;
    }

    .restoration-section,
    .virtual-session-section{
      background:var(--bg-2);
      border-top:1px solid var(--border);
      border-bottom:1px solid var(--border);
    }

    .restoration-grid,
    .virtual-session-grid,
    .gallery-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:20px;
    }

    .restoration-item,
    .virtual-session-item,
    .gallery-item{
      border-radius:8px;
      overflow:hidden;
      border:1px solid var(--border);
      background:#000;
      cursor:pointer;
      transition:.35s;
      position:relative;
    }

    .restoration-item:hover,
    .virtual-session-item:hover,
    .gallery-item:hover{
      border-color:var(--gold);
      box-shadow:0 0 30px rgba(212,175,55,0.25);
      transform:translateY(-4px);
    }

    .restoration-item img,
    .virtual-session-item img,
    .gallery-item img{
      width:100%;
      height:100%;
      display:block;
      object-fit:cover;
      transition:.45s;
    }

    .restoration-item:hover img,
    .virtual-session-item:hover img,
    .gallery-item:hover img{
      transform:scale(1.03);
    }

    .reviews{
      background:var(--bg-2);
    }

    .reviews-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
      gap:24px;
    }

    .review-card{
      background:var(--card);
      padding:30px;
      border-radius:6px;
      border:1px solid var(--border);
      position:relative;
      transition:.3s;
    }

    .review-card:hover{
      border-color:var(--gold);
      transform:translateY(-4px);
    }

    .review-card::before{
      content:'"';
      position:absolute;
      top:-10px;
      right:20px;
      font-family:'Cormorant Garamond',serif;
      font-size:90px;
      color:var(--gold);
      opacity:.3;
      line-height:1;
    }

    .review-stars{
      color:var(--gold);
      margin-bottom:14px;
      letter-spacing:3px;
    }

    .review-text{
      color:var(--text);
      font-size:14px;
      margin-bottom:24px;
      font-style:italic;
    }

    .review-author{
      display:flex;
      align-items:center;
      gap:14px;
    }

    .review-avatar{
      width:52px;
      height:52px;
      border-radius:50%;
      border:2px solid var(--gold);
      object-fit:cover;
      box-shadow:0 0 15px rgba(212,175,55,0.4);
    }

    .review-name{
      font-weight:500;
      color:var(--gold-light);
      font-size:15px;
    }

    .review-role{
      font-size:12px;
      color:var(--muted);
      letter-spacing:1px;
    }

    .cta-section{
      background:linear-gradient(135deg,rgba(212,175,55,0.05),rgba(0,229,255,0.04));
      border-top:1px solid var(--border);
      border-bottom:1px solid var(--border);
      text-align:center;
    }

    .cta-section p{
      color:var(--muted);
      max-width:700px;
      margin:0 auto 36px;
    }

    .modal-overlay{
      position:fixed;
      inset:0;
      z-index:300;
      background:rgba(5,5,10,0.85);
      backdrop-filter:blur(10px);
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      opacity:0;
      transition:opacity .3s;
    }

    .modal-overlay.active{
      display:flex;
      opacity:1;
    }

    .modal{
      background:var(--card);
      border:1px solid var(--gold);
      border-radius:10px;
      padding:40px 32px;
      max-width:460px;
      width:100%;
      box-shadow:0 0 80px rgba(212,175,55,0.4),0 0 40px rgba(0,229,255,0.15);
      position:relative;
      transform:scale(.9);
      transition:transform .3s;
      text-align:center;
    }

    .modal-overlay.active .modal{
      transform:scale(1);
    }

    .modal-close{
      position:absolute;
      top:12px;
      right:16px;
      background:none;
      border:none;
      color:var(--muted);
      font-size:28px;
      cursor:pointer;
    }

    .modal-close:hover{
      color:var(--gold);
    }

    .modal-icon{
      width:70px;
      height:70px;
      border-radius:50%;
      background:linear-gradient(135deg,var(--gold),var(--gold-light));
      display:flex;
      align-items:center;
      justify-content:center;
      margin:0 auto 18px;
      font-size:32px;
      box-shadow:0 0 30px rgba(212,175,55,0.5);
    }

    .modal h3{
      font-family:'Cormorant Garamond',serif;
      font-size:30px;
      margin-bottom:10px;
      color:var(--gold);
    }

    .modal p{
      color:var(--muted);
      margin-bottom:28px;
      font-size:14px;
    }

    .contact-links{
      display:flex;
      flex-direction:column;
      gap:12px;
    }

    .contact-link{
      display:flex;
      align-items:center;
      gap:14px;
      padding:14px 20px;
      border-radius:6px;
      text-decoration:none;
      font-weight:500;
      font-size:15px;
      transition:all .3s;
      border:1px solid transparent;
      color:var(--text);
    }

    .contact-link .ico{
      width:42px;
      height:42px;
      border-radius:8px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:700;
      font-size:14px;
      flex-shrink:0;
      color:#fff;
    }

    .contact-link .info{
      text-align:left;
      flex:1;
    }

    .contact-link .title{
      font-size:15px;
      font-weight:600;
      display:block;
    }

    .contact-link .sub{
      font-size:12px;
      opacity:.7;
      font-weight:400;
    }

    .contact-max{
      background:rgba(0,229,255,0.08);
      border-color:rgba(0,229,255,0.3);
    }

    .contact-max .ico{
      background:linear-gradient(135deg,#00e5ff,#0088ff);
    }

    .contact-vk{
      background:rgba(82,136,193,0.08);
      border-color:rgba(82,136,193,0.35);
    }

    .contact-vk .ico{
      background:linear-gradient(135deg,#5181b8,#2b587a);
    }

    .contact-ok{
      background:rgba(238,128,30,0.08);
      border-color:rgba(238,128,30,0.35);
    }

    .contact-ok .ico{
      background:linear-gradient(135deg,#ee801e,#c96600);
    }

    .contact-mail{
      background:rgba(212,175,55,0.08);
      border-color:rgba(212,175,55,0.35);
    }

    .contact-mail .ico{
      background:linear-gradient(135deg,#d4af37,#f4d77a);
      color:#0a0a0f;
    }

    .lightbox-overlay{
      position:fixed;
      inset:0;
      z-index:400;
      background:rgba(0,0,0,0.92);
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
    }

    .lightbox-overlay.active{
      display:flex;
    }

    .lightbox-content{
      position:relative;
      width:min(100%, 1280px);
      display:flex;
      flex-direction:column;
      gap:16px;
      align-items:center;
    }

    .lightbox-image-wrap{
      width:100%;
      max-height:82vh;
      display:flex;
      align-items:center;
      justify-content:center;
      background:#000;
      border:1px solid var(--border);
      border-radius:10px;
      overflow:hidden;
      box-shadow:0 0 50px rgba(212,175,55,0.2);
    }

    .lightbox-image{
      width:100%;
      max-height:82vh;
      object-fit:contain;
      display:block;
      background:#000;
    }

    .lightbox-close,
    .lightbox-prev,
    .lightbox-next{
      position:absolute;
      border:none;
      cursor:pointer;
      color:#0a0a0f;
      background:linear-gradient(135deg,var(--gold),var(--gold-light));
      box-shadow:0 0 25px rgba(212,175,55,0.4);
    }

    .lightbox-close{
      top:-10px;
      right:0;
      width:44px;
      height:44px;
      border-radius:50%;
      font-size:24px;
      z-index:3;
    }

    .lightbox-prev,
    .lightbox-next{
      top:50%;
      transform:translateY(-50%);
      width:54px;
      height:54px;
      border-radius:50%;
      font-size:24px;
      z-index:3;
    }

    .lightbox-prev{left:-10px}
    .lightbox-next{right:-10px}

    .lightbox-thumbs{
      width:100%;
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(90px,1fr));
      gap:10px;
    }

    .lightbox-thumb{
      border:1px solid var(--border);
      border-radius:6px;
      overflow:hidden;
